<?xml version="1.0"?>
<robot name="four_wheel_diff_drive" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ******************** 可配置参数 ******************** -->
  <xacro:property name="base_length" value="0.5" />
  <xacro:property name="base_width" value="0.3" />
  <xacro:property name="base_height" value="0.1" />
  <xacro:property name="base_mass" value="12.0" />
  <xacro:property name="base_elevation" value="0.05" />
  
  <xacro:property name="wheel_radius" value="0.1" />
  <xacro:property name="wheel_width" value="0.06" />
  <xacro:property name="wheel_mass" value="1.0" />
  
  <!-- 车轮位置计算 -->
  <xacro:property name="wheel_pos_x" value="0.2" />
  <xacro:property name="wheel_pos_y" value="0.15" />
  <xacro:property name="wheel_pos_z" value="0.0" />
  
  <!-- 材料颜色定义 -->
  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.2 0.2 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <!-- ******************** 惯性宏 ******************** -->
  <xacro:macro name="default_inertia" params="mass">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia 
        ixx="${0.1 * mass}" ixy="0.0" ixz="0.0"
        iyy="${0.1 * mass}" iyz="0.0"
        izz="${0.1 * mass}" />
    </inertial>
  </xacro:macro>

  <!-- ******************** 车轮宏 ******************** -->
  <xacro:macro name="wheel" params="side prefix *joint_pose">
    <link name="${prefix}_${side}_wheel">
      <xacro:default_inertia mass="${wheel_mass}"/>
      <visual>
        <!-- 修正：圆柱体绕Y轴旋转使轴线朝Y方向，但差速驱动车轮应绕Y轴旋转 -->
        <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}_${side}_wheel_joint" type="continuous">
      <parent link="${prefix}_link"/>
      <child link="${prefix}_${side}_wheel"/>
      <xacro:insert_block name="joint_pose" />
      <!-- 修正：车轮绕Y轴旋转，这是正确的方向 -->
      <axis xyz="0 1 0"/>
      <limit effort="100" velocity="10"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>
  </xacro:macro>

  <!-- ******************** 车身 (base_link) ******************** -->
  <link name="base_link">
    <xacro:default_inertia mass="${base_mass}"/>
    <visual>
      <origin xyz="0 0 ${base_elevation}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_elevation}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ******************** 四个轮子 (使用宏) ******************** -->
  <!-- 注意：差速驱动四轮配置，所有轮子绕Y轴旋转是正确的方向 -->
  
  <xacro:wheel side="front_left" prefix="base">
    <joint_pose xyz="${wheel_pos_x} ${wheel_pos_y} ${wheel_pos_z}" rpy="0 0 0"/>
  </xacro:wheel>

  <xacro:wheel side="front_right" prefix="base">
    <joint_pose xyz="${wheel_pos_x} ${-wheel_pos_y} ${wheel_pos_z}" rpy="0 0 0"/>
  </xacro:wheel>

  <xacro:wheel side="rear_left" prefix="base">
    <joint_pose xyz="${-wheel_pos_x} ${wheel_pos_y} ${wheel_pos_z}" rpy="0 0 0"/>
  </xacro:wheel>

  <xacro:wheel side="rear_right" prefix="base">
    <joint_pose xyz="${-wheel_pos_x} ${-wheel_pos_y} ${wheel_pos_z}" rpy="0 0 0"/>
  </xacro:wheel>

  <!-- ******************** IMU模块 ******************** -->
  <link name="imu_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.1 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ******************** 摄像机模块 ******************** -->
  <link name="camera_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.25 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>